# ── LLM API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── LLM Provider ──────────────────────────────────────────────────────────────
# 選擇 LLM 提供商: ollama (本地免費) | anthropic | deepseek
LLM_PROVIDER=ollama

# Ollama — 透過 Tailscale Serve 存取 (https://...ts.net/ollama)
# 本機開發直連: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# Anthropic API (LLM_PROVIDER=anthropic 時使用)
# ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek API (LLM_PROVIDER=deepseek 時使用)
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# ── Blender 連線 ───────────────────────────────────────────────────────────────
BLENDER_HOST=localhost
BLENDER_PORT=9876

# ── 伺服器 ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=17823

# ── CORS ───────────────────────────────────────────────────────────────────────
# 透過 Tailscale Serve 存取時，前端 origin 是 Tailnet 網址
# MacHomeHub 管理介面: https://bearmacminimac-mini.tail56c751.ts.net
CORS_ORIGINS=https://bearmacminimac-mini.tail56c751.ts.net,http://localhost:19147

# ── Tailscale / MacHomeHub ─────────────────────────────────────────────────────
# Tailnet URL（由 Tailscale Serve 路由 /blender → localhost:19147）
# TAILNET_BASE_URL=https://bearmacminimac-mini.tail56c751.ts.net/blender

# ── Workflow ───────────────────────────────────────────────────────────────────
DEFAULT_WORKFLOW=conversational_modeling

# ── Text-to-3D (Hunyuan3D-2) ──────────────────────────────────────────────────
# gradio = HuggingFace Space (預設，不需 GPU)
# local  = 本地伺服器 (需要 GPU + HUNYUAN3D_ENDPOINT)
# HUNYUAN3D_MODE=gradio
# HUNYUAN3D_ENDPOINT=http://localhost:8080
